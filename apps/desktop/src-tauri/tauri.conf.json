{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Greenseer",
  "version": "0.1.0",
  "identifier": "com.greenseer.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Greenseer",
        "width": 1440,
        "height": 900,
        "minWidth": 800,
        "minHeight": 640,
        "decorations": true,
        "center": true,
        "maximizable": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:* http://localhost:* https://api.adzuna.com https://api.anthropic.com; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/greenseer-sidecar"
    ]
  }
}
