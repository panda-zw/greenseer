{
  "name": "@greenseer/sidecar",
  "private": true,
  "version": "0.1.0",
  "description": "Greenseer NestJS sidecar backend",
  "license": "MIT",
  "scripts": {
    "start:dev": "tsc -w -p tsconfig.json & node --watch dist/main.js",
    "start:prod": "node dist/main.js",
    "build": "tsc -p tsconfig.json",
    "build:bundle": "node esbuild.config.mjs",
    "build:binary": "pnpm build && pnpm build:bundle && pnpm exec pkg dist/bundle.cjs --targets node20-macos-arm64,node20-macos-x64,node20-win-x64 --output dist/greenseer-sidecar && node scripts/copy-prisma-engine.mjs",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@greenseer/shared": "workspace:*",
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/platform-express": "^10.4.22",
    "@nestjs/schedule": "^4.1.0",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^6.2.0",
    "axios": "^1.14.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "crypto-js": "^4.2.0",
    "docx": "^9.6.1",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "pdf-parse": "1.1.1",
    "playwright-core": "^1.59.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sharp": "^0.34.5",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@nestjs/schematics": "^10.2.0",
    "@nestjs/testing": "^10.4.0",
    "@types/crypto-js": "^4.2.2",
    "@types/jest": "^29.5.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.0.0",
    "@yao-pkg/pkg": "^5.15.0",
    "esbuild": "^0.24.0",
    "jest": "^29.7.0",
    "prisma": "^6.2.0",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.2.0",
    "typescript": "^5.7.0"
  },
  "pkg": {
    "scripts": "dist/bundle.cjs",
    "assets": [
      "node_modules/.prisma/client/*.node",
      "node_modules/@prisma/client/**/*.js",
      "prisma/schema.prisma"
    ],
    "outputPath": "dist"
  }
}
