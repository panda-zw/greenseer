{
  "name": "@greenseer/shared",
  "private": true,
  "version": "0.1.0",
  "description": "Shared types for Greenseer desktop and sidecar",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
